---
import Button from "./Button.astro";
import type { Product } from "@data/products";
import type { LanguageCode } from "@lib/i18n";
import { localizedPath } from "@lib/i18n";

type Props = {
  product: Product;
  lang: LanguageCode;
};

const { product, lang } = Astro.props;
---

<article class="flex h-full flex-col rounded-card border border-surface-border bg-white p-4 shadow-card transition hover:border-brand-blue">
  <div class="aspect-[4/3] rounded-media bg-gradient-to-br from-brand-blueLight to-surface-soft">
    <div class="flex h-full items-end p-5">
      <span class="rounded-control bg-white px-3 py-2 text-caption-sm text-brand-blue shadow-soft">{product.model}</span>
    </div>
  </div>
  <div class="flex flex-1 flex-col pt-5">
    <p class="text-caption-sm uppercase tracking-[0.12em] text-ink-muted">{product.chairTier ?? product.category}</p>
    <h3 class="mt-2 text-heading-lg text-ink-primary">{product.title}</h3>
    <p class="mt-3 flex-1 text-body-sm text-ink-secondary">{product.summary}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <Button href={localizedPath(lang, `/products/${product.category}/${product.slug}/`)} size="md">View Details</Button>
      <Button href={localizedPath(lang, `/contact/?product=${product.slug}`)} variant="secondary" size="md">Inquiry</Button>
    </div>
  </div>
</article>
