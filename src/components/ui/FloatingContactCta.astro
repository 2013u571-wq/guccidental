---
import { localizedPath, type LanguageCode } from "@lib/i18n";

type Props = {
  lang: LanguageCode;
};

const { lang } = Astro.props;
const contactHref = localizedPath(lang, "/contact/");
const whatsappHref = "https://wa.me/+8613825587076";
---

<div
  class="floating-contact-cta"
  data-floating-contact
  data-desktop-threshold="500"
  data-mobile-threshold="500"
  aria-label="Quick contact actions"
>
  <a
    class="floating-contact-cta__button floating-contact-cta__button--whatsapp"
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contact us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.1 3.9A10.9 10.9 0 0 0 1.5 11.6c0 1.9.5 3.8 1.5 5.4L1.4 22.8l5.9-1.5a10.9 10.9 0 0 0 5.2 1.3h.1A10.9 10.9 0 0 0 20.1 3.9Zm-7.5 16.8h-.1a9 9 0 0 1-4.6-1.3l-.3-.2-3.5.9.9-3.4-.2-.4a9 9 0 1 1 7.8 4.4Zm5-6.7c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.4-1.5-.9-.8-1.5-1.8-1.6-2.1-.2-.3 0-.4.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1.1-1.1 2.6 0 1.6 1.1 3.1 1.3 3.3.2.2 2.2 3.4 5.4 4.7.8.3 1.3.5 1.8.6.8.2 1.4.2 2 0 .6-.1 1.8-.7 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.2-.3-.2-.6-.4Z" />
    </svg>
    <span>WhatsApp</span>
  </a>

  <a
    class="floating-contact-cta__button floating-contact-cta__button--quote"
    href={contactHref}
    aria-label="Get quote"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4.8 6.5h14.4c.7 0 1.3.6 1.3 1.3v8.4c0 .7-.6 1.3-1.3 1.3H4.8c-.7 0-1.3-.6-1.3-1.3V7.8c0-.7.6-1.3 1.3-1.3Z" />
      <path d="m4.4 7.6 7.1 5.4c.3.2.7.2 1 0l7.1-5.4" />
    </svg>
    <span>Get Quote</span>
  </a>
</div>

<script>
  (() => {
    const floatingContact = document.querySelector("[data-floating-contact]");
    if (!floatingContact) return;

    const desktopThreshold = Number(floatingContact.getAttribute("data-desktop-threshold")) || 560;
    const mobileThreshold = Number(floatingContact.getAttribute("data-mobile-threshold")) || 500;
    const mobileQuery = window.matchMedia("(max-width: 767px)");

    const updateFloatingContact = () => {
      const threshold = mobileQuery.matches ? mobileThreshold : desktopThreshold;
      floatingContact.classList.toggle("is-visible", window.scrollY >= threshold);
    };

    updateFloatingContact();
    window.addEventListener("scroll", updateFloatingContact, { passive: true });
    mobileQuery.addEventListener("change", updateFloatingContact);
  })();
</script>
