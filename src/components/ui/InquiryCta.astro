---

<section class="cta-section">
  <div class="container">
    <div class="cta-layout">
      <div>
        <span class="cta-eyebrow">Factory Direct Inquiry</span>
        <h2>Tell us what your clinic needs.</h2>
        <p>Send your room count, dental chair requirements, renovation scope, destination market, and budget range. We will prepare a practical one-stop clinic supply plan.</p>
        <ul class="cta-checklist">
          <li>Factory-direct pricing, no middlemen</li>
          <li>OEM/ODM available for qualifying volumes</li>
          <li>Export documentation & door-to-door delivery</li>
          <li>Installation guidance & after-sales support</li>
        </ul>
      </div>

      <form class="cta-form" action="/contact/" method="get">
        <div class="cta-form-row">
          <div class="cta-form-field">
            <label for="inq-name">Name</label>
            <input type="text" id="inq-name" name="name" placeholder="Your name" autocomplete="name" />
          </div>
          <div class="cta-form-field">
            <label for="inq-email">Email</label>
            <input type="email" id="inq-email" name="email" placeholder="your@email.com" autocomplete="email" />
          </div>
        </div>
        <div class="cta-form-field">
          <label for="inq-whatsapp">WhatsApp / Phone</label>
          <input type="tel" id="inq-whatsapp" name="whatsapp" placeholder="+1 234 567 8900" autocomplete="tel" />
        </div>
        <div class="cta-form-field">
          <label for="inq-message">Message</label>
          <textarea id="inq-message" name="message" rows="3" placeholder="Describe your clinic project, room count, chair requirements..."></textarea>
        </div>
        <div class="cta-form-actions">
          <label class="cta-upload-label">
            <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 3v10M6 7l4-4 4 4M4 15h12" />
            </svg>
            Attach file
            <input type="file" name="attachment" accept=".pdf,.doc,.docx,.jpg,.png" />
          </label>
          <button type="submit" class="cta-submit-btn">Send Inquiry</button>
        </div>
      </form>
    </div>
  </div>
</section>
