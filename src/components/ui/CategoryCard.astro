---
import type { Category } from "@data/products";
import type { LanguageCode } from "@lib/i18n";
import { localizedPath } from "@lib/i18n";

type Props = {
  category: Category;
  lang: LanguageCode;
};

const { category, lang } = Astro.props;
---

<a href={localizedPath(lang, `/products/${category.slug}/`)} class="group rounded-card border border-surface-border bg-white p-6 shadow-card transition hover:border-brand-blue">
  <div class="mb-8 h-12 w-12 rounded-control bg-brand-blueLight text-brand-blue">
    <span class="grid h-full place-items-center text-heading-md">{category.title.slice(0, 2)}</span>
  </div>
  <h3 class="text-heading-lg text-ink-primary group-hover:text-brand-blue">{category.title}</h3>
  <p class="mt-3 text-body-sm text-ink-secondary">{category.summary}</p>
</a>
