---
import { footerGroups, site } from "@data/site";
import { localizedPath, type LanguageCode } from "@lib/i18n";

type Props = {
  lang: LanguageCode;
};

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="container footer-main grid gap-10 py-16 lg:grid-cols-[1.2fr_2fr]">
    <div class="footer-intro">
      <a href={localizedPath(lang, "/")} class="footer-brand">
        <span class="footer-brand__mark" aria-hidden="true">G</span>
        <span class="footer-brand__name">GUCCIDENT</span>
      </a>
      <p class="footer-description">Guccident helps dental clinic owners plan, equip, furnish, ship, and support new clinics and chair replacement projects from one source.</p>
      <div class="footer-contact">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href="https://wa.me/+8613825587076" target="_blank" rel="noopener noreferrer">{site.whatsapp}</a>
        <p>{site.address}</p>
      </div>
    </div>
    <div class="footer-groups footer-groups--desktop grid gap-8 sm:grid-cols-3">
      {
        footerGroups.map((group) => (
          <div>
            <h2 class="footer-heading">{group.title}</h2>
            <ul class="footer-links">
              {group.links.map((link) => (
                <li>
                  <a href={localizedPath(lang, link.href)}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="footer-groups footer-groups--mobile">
      {
        footerGroups.map((group) => (
          <details class="footer-mobile-group">
            <summary>{group.title}<span aria-hidden="true"></span></summary>
            <ul class="footer-links">
              {group.links.map((link) => (
                <li>
                  <a href={localizedPath(lang, link.href)}>{link.label}</a>
                </li>
              ))}
            </ul>
          </details>
        ))
      }
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p class="footer-copyright">© {new Date().getFullYear()} {site.companyName}.</p>
      <div class="footer-certs" aria-label="Certifications">
        <span>CE</span>
        <span>ISO</span>
        <span>FDA</span>
        <span>SGS</span>
      </div>
    </div>
  </div>
</footer>
