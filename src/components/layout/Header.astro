---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import NavChevron from "./NavChevron.astro";
import { localizedPath, type LanguageCode } from "@lib/i18n";
import { site } from "@data/site";

type Props = {
  lang: LanguageCode;
};

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const contactHref = localizedPath(lang, "/contact/");

const primaryNavigation = [
  { label: "Products", href: "/products/" },
  { label: "Solutions", href: "/solutions/" },
  { label: "Cases", href: "/cases/" },
  { label: "Resources", href: "/resources/" },
  { label: "About Us", href: "/about/" },
  { label: "Contact", href: "/contact/" }
];

const standardDesktopNavigation = primaryNavigation.filter((item) => !["Products", "Solutions", "Contact"].includes(item.label));

type MegaMenuLink = {
  label: string;
  description: string;
  href: string;
};

type MegaMenuCategory = {
  title: string;
  href: string;
  links?: MegaMenuLink[];
};

type MegaMenuGroup = {
  title: string;
  stageTitle?: string;
  href?: string;
  links?: MegaMenuLink[];
  categories?: MegaMenuCategory[];
};

const megaGroups: MegaMenuGroup[] = [
  {
    title: "Chairs & Cabinets",
    href: "/products/",
    categories: [
      { title: "Dental Chair", href: "/products/dental-chair/", links: [{ label: "High-end Series", description: "Crafted with cutting-edge technology, premium materials, pioneering design.", href: "/products/dental-chair/high-end/" }, { label: "Mid-range Series", description: "Optimal comfort & configuration for daily dental work.", href: "/products/dental-chair/mid-range/" }, { label: "Economic Series", description: "Complete basic functions for cost-effective clinics.", href: "/products/dental-chair/economic/" }] },
      { title: "Dental Cabinet", href: "/products/dental-cabinet/", links: [{ label: "Metal Cabinet", description: "Seamless surfaces built for strict hygiene protocols.", href: "/products/dental-cabinet/metal/" }, { label: "Wood Cabinet", description: "Warm finishes for reception-facing treatment rooms.", href: "/products/dental-cabinet/wood/" }] }
    ]
  },
  {
    title: "Treatment Equipment",
    links: [{ label: "Ultrasonic Scaler", description: "Scaling and curing equipment for daily treatment workflows.", href: "/products/ultrasonic-scaler-light-cure/" }, { label: "Air Equipment", description: "Compressors and vacuum systems for stable clinic operation.", href: "/products/air-equipment/" }, { label: "Dental Handpiece", description: "High-speed and low-speed handpieces for daily use.", href: "/products/dental-handpiece/" }, { label: "Endo Motor", description: "Torque-controlled motors for root canal preparation.", href: "/products/endo-motor/" }]
  },
  {
    title: "Imaging & Digital",
    stageTitle: "Imaging System",
    href: "/products/imaging-system/",
    links: [{ label: "X-ray", description: "Intraoral units for routine diagnostic imaging.", href: "/products/imaging-system/x-ray/" }, { label: "CBCT", description: "3D volumetric imaging for implant and surgical planning.", href: "/products/imaging-system/cbct/" }, { label: "Intraoral Scanner", description: "Digital impressions without trays or impression material.", href: "/products/imaging-system/intraoral-scanner/" }, { label: "Intraoral Camera", description: "Chairside documentation and patient communication.", href: "/products/imaging-system/intraoral-camera/" }]
  },
  {
    title: "Specialty & Supplies",
    links: [{ label: "Orthodontics", description: "Brackets, wires and chairside orthodontic tools.", href: "/products/orthodontics/" }, { label: "Surgical Instruments", description: "Implant motors, surgical kits and hand instruments.", href: "/products/surgical-instruments/" }, { label: "Whitening Machine", description: "In-clinic bleaching lamps.", href: "/products/whitening-machine/" }, { label: "Disposable Consumables", description: "Gloves, bibs, tips and everyday clinic supplies.", href: "/products/disposable-consumables/" }, { label: "Teaching Model", description: "Phantom heads and typodonts for dental education.", href: "/products/teaching-model/" }, { label: "Laboratory", description: "Equipment for in-house lab workflows.", href: "/products/laboratory/" }]
  }
];
const solutionMegaColumns = [
  {
    title: "New Clinic",
    menuLabel: "New Clinic",
    href: "/solutions/new-clinic/",
    description: "Plan a complete clinic from layout and equipment selection to furniture, materials, shipping, and installation support.",
    items: ["Layout planning", "Equipment package", "Installation support"]
  },
  {
    title: "Replace Old Chairs",
    menuLabel: "Replace Old Chairs",
    href: "/solutions/clinic-upgrade/",
    description: "Upgrade outdated dental chairs with practical models, matching accessories, delivery planning, and after-sales guidance.",
    items: ["Model matching", "Accessories", "After-sales support"]
  },
  {
    title: "Clinic Renovation",
    menuLabel: "Clinic Renovation",
    href: "/solutions/clinic-renovation/",
    description: "Refresh treatment rooms with chairs, cabinets, flooring, ceiling materials, lighting, consumables, and technical support.",
    items: ["Room refresh", "Cabinets & materials", "Technical support"]
  },
  {
    // TODO: 待 Building Materials 页面上线后补链接
    title: "Building Materials & Furniture",
    menuLabel: "Building Materials",
    href: "/solutions/",
    description: "Fit-out materials and furniture for the whole clinic.",
    items: ["Flooring", "Ceiling", "Doors & Windows", "Reception Desk", "Sofa", "Chair"]
  }
] as const;

const socialLinks = [
  { label: "Contact us", href: contactHref },
  { label: "Facebook", href: "#" },
  { label: "LinkedIn", href: "#" },
  { label: "YouTube", href: "#" }
];

const isNavActive = (href: string) => {
  const path = localizedPath(lang, href).split("?")[0];
  return currentPath === path || currentPath.startsWith(path);
};
---

<header class="site-header sticky inset-x-0 top-0 z-40 border-b" data-site-header>
  <div class="container flex min-h-16 items-center justify-between gap-5">
    <a href={localizedPath(lang, "/")} class="flex shrink-0 items-center gap-3" aria-label={`${site.name} home`}>
      <img src="/assets/guccidental-logo.png" alt={site.name} class="h-8 w-auto" />
    </a>

    <nav class="product-primary-nav hidden min-w-0 flex-1 items-center justify-center lg:flex" aria-label="Primary navigation">
      <div class="products-mega" data-products-mega>
        <button type="button" class:list={["product-nav-trigger", "nav-item", "products-mega__trigger", isNavActive("/products/") && "is-active"]} aria-expanded="false" aria-controls="products-mega-panel" data-products-mega-trigger>
          Products <NavChevron />
        </button>
        <div class="mega-panel" id="products-mega-panel" data-products-mega-panel>
          <div class="container mega-catalog">
            <nav class="mega-rail" aria-label="Product groups">
              {megaGroups.map((group, index) => <button type="button" class:list={["mega-rail-item", index === 0 && "is-active"]} data-mega-group-tab={index}>{group.title}</button>)}
              <a class="mega-rail-cta" href={localizedPath(lang, "/products/")}>Explore all products<svg class="mega-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg></a>
            </nav>
            <section class="mega-stage" aria-label="Product categories">
              {megaGroups.map((group, index) => (
                <div class:list={["mega-stage-panel", index === 0 && "is-active"]} data-mega-group-panel={index}>
                  {group.categories ? (
                    <div class="mega-stage-grid">
                    {group.categories.map((category) => (
                      <section class="mega-category-block">
                        <a class="mega-category-title" href={localizedPath(lang, category.href)}>{category.title}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg></a>
                        {category.links?.map((link) => <a class="mega-item" href={localizedPath(lang, link.href)}><span class="mega-item-name">{link.label}</span><span class="mega-item-desc">{link.description}</span></a>)}
                      </section>
                    ))}
                    </div>
                  ) : (
                    <>
                      {group.stageTitle && group.href && <a class="mega-stage-title" href={localizedPath(lang, group.href)}>{group.stageTitle}<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg></a>}
                      <div class="mega-stage-grid">{group.links?.map((link) => <a class="mega-item" href={localizedPath(lang, link.href)}><span class="mega-item-name">{link.label}</span><span class="mega-item-desc">{link.description}</span></a>)}</div>
                    </>
                  )}
                </div>
              ))}
            </section>
          </div>
        </div>
      </div>
      <div class="solutions-menu" data-solutions-mega>
        <button type="button" class:list={["product-nav-trigger", "nav-item", "solutions-menu__trigger", isNavActive("/solutions/") && "is-active"]} aria-expanded="false" aria-controls="solutions-mega-panel" data-solutions-mega-trigger>
          Solutions <NavChevron />
        </button>
        <div class="solutions-mega-panel" id="solutions-mega-panel" data-solutions-mega-panel>
          <div class="container sol-panel">
            <div class="sol-cols">
              {solutionMegaColumns.map((column) => (
                <div class="sol-col">
                  <a class="sol-col-title" href={localizedPath(lang, column.href)}>
                    <span>{column.menuLabel}</span>
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3 9h12M10.5 4.5 15 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                  <p class="sol-col-desc">{column.description}</p>
                  <ul class="sol-col-list sol-col-divider">
                    {column.items.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      {standardDesktopNavigation.map((item) => <a href={localizedPath(lang, item.href)} class:list={["product-nav-trigger", isNavActive(item.href) && "is-active"]} aria-current={isNavActive(item.href) ? "page" : undefined}>{item.label}</a>)}
      <a
        href={contactHref}
        class="site-header-cta rounded-control bg-brand-blue px-4 py-2.5 text-button-caps text-white transition hover:bg-brand-blueDark"
        aria-current={isNavActive("/contact/") ? "page" : undefined}
      >
        Contact
      </a>
    </nav>

    <div class="header-actions hidden shrink-0 items-center gap-3 lg:flex">
      <div class="header-language">
        <LanguageSwitcher lang={lang} id="desktop-language-switcher" />
      </div>

      <div class="header-socials social-icons" aria-label="Social media">
        {
          socialLinks.map((item) => (
            <>
              <a href={item.href} class="header-social-link" aria-label={item.label}>
                {item.label === "Contact us" && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8" />
                    <path d="M3 6.5 12 13l9-6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {item.label === "Facebook" && (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 8h2V4h-2c-3 0-5 2-5 5v3H7v4h2v4h4v-4h3l1-4h-4V9c0-.6.4-1 1-1Z" />
                  </svg>
                )}
                {item.label === "LinkedIn" && (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="16" height="16" x="4" y="4" rx="2" />
                    <path d="M8 11v5" />
                    <path d="M8 8.5v.01" />
                    <path d="M12 16v-5" />
                    <path d="M12 13.5c0-1.4 1-2.5 2.3-2.5 1.5 0 2.2 1 2.2 2.7V16" />
                  </svg>
                )}
                {item.label === "YouTube" && (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="18" height="12" x="3" y="6" rx="3" />
                    <path d="m10 9 5 3-5 3Z" />
                  </svg>
                )}
              </a>
              {item.label === "Contact us" && <span class="header-divider" aria-hidden="true"></span>}
            </>
          ))
        }
      </div>
    </div>

    <details class="mobile-menu lg:hidden">
      <summary class="mobile-menu__trigger" aria-label="Open navigation menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <div class="mobile-menu__panel">
        <nav class="mobile-menu__links" aria-label="Mobile navigation">
          <details class="mobile-products">
            <summary class="mobile-menu__link">Products</summary>
            <div class="mobile-products__groups">
              {megaGroups.map((group) => (
                <details class="mobile-product-item">
                  <summary>{group.title}</summary>
                  <div class="mobile-product-item__links">
                    {group.categories ? group.categories.map((category) => (
                      <div class="mobile-product-category">
                        <a class="mobile-product-category__title" href={localizedPath(lang, category.href)}>{category.title} <span aria-hidden="true">→</span></a>
                        {category.links?.map((link) => <a href={localizedPath(lang, link.href)}><span>{link.label}</span><small>{link.description}</small></a>)}
                      </div>
                    )) : group.links?.map((link) => <a href={localizedPath(lang, link.href)}><span>{link.label}</span><small>{link.description}</small></a>)}
                  </div>
                </details>
              ))}
            </div>
          </details>
          <details class="mobile-solutions">
            <summary class="mobile-menu__link">Solutions</summary>
            <div class="mobile-solutions__groups">
              {solutionMegaColumns.map((column) => (
                <details class="mobile-solution-item">
                  <summary>{column.title}</summary>
                  <div class="mobile-solution-item__content">
                    <p>{column.description}</p>
                    <ul>{column.items.map((item) => <li>{item}</li>)}</ul>
                  </div>
                </details>
              ))}
            </div>
          </details>
          {
            primaryNavigation.filter((item) => !["Products", "Solutions"].includes(item.label)).map((item) => (
              <a
                href={localizedPath(lang, item.href)}
                class:list={[
                  "mobile-menu__link",
                  isNavActive(item.href) && "is-active"
                ]}
                aria-current={isNavActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="mobile-menu__tools">
          <LanguageSwitcher lang={lang} id="mobile-language-switcher" />
        </div>

        <div class="header-socials social-icons mobile-menu__socials" aria-label="Social media">
          {
            socialLinks.map((item) => (
              <>
                <a href={item.href} class="header-social-link" aria-label={item.label}>
                  {item.label === "Contact us" && (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8" />
                      <path d="M3 6.5 12 13l9-6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {item.label === "Facebook" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M14 8h2V4h-2c-3 0-5 2-5 5v3H7v4h2v4h4v-4h3l1-4h-4V9c0-.6.4-1 1-1Z" />
                    </svg>
                  )}
                  {item.label === "LinkedIn" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="16" height="16" x="4" y="4" rx="2" />
                      <path d="M8 11v5" />
                      <path d="M8 8.5v.01" />
                      <path d="M12 16v-5" />
                      <path d="M12 13.5c0-1.4 1-2.5 2.3-2.5 1.5 0 2.2 1 2.2 2.7V16" />
                    </svg>
                  )}
                  {item.label === "YouTube" && (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect width="18" height="12" x="3" y="6" rx="3" />
                      <path d="m10 9 5 3-5 3Z" />
                    </svg>
                  )}
                </a>
                {item.label === "Contact us" && <span class="header-divider" aria-hidden="true"></span>}
              </>
            ))
          }
        </div>
      </div>
    </details>
  </div>
</header>

<script>
  const mega = document.querySelector<HTMLElement>("[data-products-mega]");
  const trigger = document.querySelector<HTMLButtonElement>("[data-products-mega-trigger]");
  const panel = document.querySelector<HTMLElement>("[data-products-mega-panel]");
  const solutionsMega = document.querySelector<HTMLElement>("[data-solutions-mega]");
  const solutionsTrigger = document.querySelector<HTMLButtonElement>("[data-solutions-mega-trigger]");
  const solutionsPanel = document.querySelector<HTMLElement>("[data-solutions-mega-panel]");
  const groupTabs = document.querySelectorAll<HTMLButtonElement>("[data-mega-group-tab]");
  const groupPanels = document.querySelectorAll<HTMLElement>("[data-mega-group-panel]");

  const closeMega = () => {
    mega?.classList.remove("is-open");
    panel?.classList.remove("is-open");
    trigger?.classList.remove("is-open");
    trigger?.setAttribute("aria-expanded", "false");
  };

  const closeSolutionsMega = () => {
    solutionsMega?.classList.remove("is-open");
    solutionsPanel?.classList.remove("is-open");
    solutionsTrigger?.classList.remove("is-open");
    solutionsTrigger?.setAttribute("aria-expanded", "false");
  };

  trigger?.addEventListener("click", () => {
    closeSolutionsMega();
    const isOpen = mega?.classList.toggle("is-open") ?? false;
    panel?.classList.toggle("is-open", isOpen);
    trigger.classList.toggle("is-open", isOpen);
    trigger.setAttribute("aria-expanded", String(isOpen));
  });

  solutionsTrigger?.addEventListener("click", () => {
    closeMega();
    const isOpen = solutionsMega?.classList.toggle("is-open") ?? false;
    solutionsPanel?.classList.toggle("is-open", isOpen);
    solutionsTrigger.classList.toggle("is-open", isOpen);
    solutionsTrigger.setAttribute("aria-expanded", String(isOpen));
  });

  document.addEventListener("click", (event) => {
    if (mega && event.target instanceof Node && !mega.contains(event.target)) closeMega();
    if (solutionsMega && event.target instanceof Node && !solutionsMega.contains(event.target)) closeSolutionsMega();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMega();
      closeSolutionsMega();
    }
  });

  groupTabs.forEach((tab) => {
    const activate = () => {
      const groupIndex = tab.dataset.megaGroupTab;
      groupTabs.forEach((item) => item.classList.toggle("is-active", item === tab));
      groupPanels.forEach((panel) => panel.classList.toggle("is-active", panel.dataset.megaGroupPanel === groupIndex));
    };
    tab.addEventListener("mouseenter", activate);
    tab.addEventListener("focus", activate);
    tab.addEventListener("click", activate);
  });

</script>
