  <InquiryCta
    lang={lang}
    title="Tell us what your clinic needs."
    summary="Send your room count, dental chair requirements, renovation scope, destination market, and budget range. We will prepare a practical one-stop clinic supply plan."
  />

  <script is:inline>
    (() => {
      const faqList = document.querySelector("[data-faq-list]");
      if (!faqList) return;

      faqList.querySelectorAll(".faq-q").forEach((button) => {
        button.addEventListener("click", () => {
          const item = button.closest(".faq-item");
          if (!item) return;

          const wasOpen = item.classList.contains("open");
          faqList.querySelectorAll(".faq-item.open").forEach((openItem) => {
            openItem.classList.remove("open");
            openItem.querySelector(".faq-q")?.setAttribute("aria-expanded", "false");
          });

          if (!wasOpen) {
            item.classList.add("open");
            button.setAttribute("aria-expanded", "true");
          }
        });
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const hero = document.querySelector("[data-hero]");
      if (!hero) return;

      const video = hero.querySelector("[data-hero-video]");
      const poster = hero.querySelector("[data-video-poster]");

      if (video) {
        const revealVideo = () => {
          video.classList.add("is-ready");
          poster?.classList.add("is-hidden");
        };
        video.addEventListener("loadeddata", revealVideo, { once: true });
        video.addEventListener("canplay", revealVideo, { once: true });
        video.play().catch(() => {});
      }

      const statNumbers = Array.from(document.querySelectorAll("[data-stat-number]"));
      const statsSection = document.querySelector("#trust-proof");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const formatter = new Intl.NumberFormat("en-US");

      const setStatValue = (element, value) => {
        element.textContent = `${formatter.format(value)}+`;
      };

      const setFinalValues = () => {
        statNumbers.forEach((element) => {
          setStatValue(element, Number(element.dataset.statTarget || "0"));
        });
      };

      if (!statsSection || statNumbers.length === 0 || reduceMotion) {
        setFinalValues();
        return;
      }

      statNumbers.forEach((element) => setStatValue(element, 0));

      const animateStats = () => {
        const duration = 1100;
        const start = performance.now();

        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);

          statNumbers.forEach((element) => {
            const target = Number(element.dataset.statTarget || "0");
            setStatValue(element, Math.round(target * eased));
          });

          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            setFinalValues();
          }
        };

        requestAnimationFrame(tick);
      };

      if (!("IntersectionObserver" in window)) {
        animateStats();
        return;
      }

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return;
          observer.disconnect();
          animateStats();
        },
        { threshold: 0.35, rootMargin: "0px 0px -12% 0px" }
      );

      observer.observe(statsSection);
    })();
  </script>

