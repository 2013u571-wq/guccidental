---
import BaseLayout from "@components/layout/BaseLayout.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import { getLanguage, localizedPath } from "@lib/i18n";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }];
}

const lang = getLanguage(Astro.params.lang);

const facts = [
  ["Location", "Kenya"],
  ["Clinic Rooms", "Multi-room clinic"],
  ["Project Type", "New clinic fit-out"],
  ["Service Scope", "Design · Supply · Delivery · Support"]
];

const processSteps = [
  {
    eyebrow: "Step 01",
    title: "Clinic plan and layout direction",
    body: "The project starts with room count, reception flow, treatment zones, furniture requirements, and procurement priorities.",
    image: "https://media.guccidental.com/assets/solutions/solution-new-clinic-layout.webp",
    alt: "Dental clinic floor plan layout used for a new clinic project"
  },
  {
    eyebrow: "Step 02",
    title: "Matched equipment and fit-out package",
    body: "Dental chairs, cabinets, lighting, materials, consumables, and logistics are coordinated as one practical clinic supply plan.",
    image: "https://media.guccidental.com/assets/solutions/solution-clinic-renovation-treatment-room.webp",
    alt: "Dental treatment room fit-out with chairs, cabinets, flooring, and lighting"
  },
  {
    eyebrow: "Step 03",
    title: "Delivery, installation support, and opening day",
    body: "The final package supports installation guidance, export coordination, and the clinic preparation process through opening day.",
    image: "https://media.guccidental.com/images/cases/kenya-clinic-reception.webp",
    alt: "White Orchid Dental and Aesthetics reception area in Kenya"
  }
];
---

<BaseLayout
  title="Kenya Clinic Fit-out Case Study"
  description="A Kenya dental clinic fit-out case study showing how Guccidental supports a new clinic from planning to opening day."
  lang={lang}
  pathname={Astro.url.pathname}
>
  <article class="case-detail-page">
    <section class="case-detail-hero">
      <div class="container">
        <nav class="case-breadcrumb" aria-label="Breadcrumb">
          <a href={localizedPath(lang, "/")}>Home</a>
          <span>/</span>
          <a href={localizedPath(lang, "/cases/")}>Cases</a>
          <span>/</span>
          <span>Kenya Clinic Fit-out</span>
        </nav>

        <div class="case-detail-hero__grid">
          <div class="case-detail-hero__copy">
            <p class="eyebrow">Case Study · Kenya</p>
            <h1>Kenya clinic fit-out from planning to opening day</h1>
            <p class="lead">A real clinic project showing how layout planning, equipment selection, delivery coordination, and installation support connect into one practical procurement path.</p>
            <p class="case-auth-note">Public display requires client authorization for White Orchid Dental &amp; Aesthetics branding before production deployment.</p>
          </div>

          <figure class="case-detail-hero__media">
            <picture>
              <source srcset="https://media.guccidental.com/images/cases/kenya-clinic-reception.webp" type="image/webp" />
              <img
                src="https://media.guccidental.com/images/cases/kenya-clinic-reception.jpg"
                alt="White Orchid Dental and Aesthetics reception area in Kenya"
                width="1160"
                height="1450"
                loading="eager"
                decoding="async"
              />
            </picture>
          </figure>
        </div>

        <div class="case-fact-bar">
          {facts.map(([label, value]) => (
            <div>
              <p class="fact-label">{label}</p>
              <p class="fact-value">{value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="case-process-band">
      <div class="container">
        <div class="case-section-head">
          <p class="eyebrow">Project Process</p>
          <h2>The same three-step path, applied to a real clinic</h2>
        </div>

        <div class="case-process-list">
          {processSteps.map((step, index) => (
            <section class={`case-process-step ${index % 2 === 1 ? "is-reversed" : ""}`}>
              <div class="case-process-copy">
                <p class="eyebrow">{step.eyebrow}</p>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
              <figure class="case-process-media">
                <img src={step.image} alt={step.alt} width="1200" height="900" loading="lazy" decoding="async" />
              </figure>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="case-vr-band">
      <div class="container">
        <div class="case-section-head">
          <p class="eyebrow">360° Walkthrough</p>
          <h2>View the clinic space in VR</h2>
          <p class="lead">The embedded tour is connected for preview. Confirm external sharing permission before public deployment.</p>
        </div>
        <div class="case-vr-frame">
          <iframe
            src="https://vr.justeasy.cn/view/1764r2961079n6h1-1763015116.html"
            title="Kenya clinic 360 degree VR walkthrough"
            loading="lazy"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <section class="case-compare-band">
      <div class="container">
        <div class="case-section-head">
          <p class="eyebrow">Result</p>
          <h2>Design intent and finished clinic view</h2>
        </div>
        <div class="case-compare-grid">
          <figure>
            <img src="https://media.guccidental.com/assets/solutions/solution-clinic-renovation-treatment-room.webp" alt="Dental clinic design visualization with treatment room equipment" width="1200" height="900" loading="lazy" decoding="async" />
            <figcaption>Design direction</figcaption>
          </figure>
          <figure>
            <picture>
              <source srcset="https://media.guccidental.com/images/cases/kenya-clinic-reception.webp" type="image/webp" />
              <img src="https://media.guccidental.com/images/cases/kenya-clinic-reception.jpg" alt="Finished White Orchid Dental and Aesthetics reception in Kenya" width="1160" height="1450" loading="lazy" decoding="async" />
            </picture>
            <figcaption>Finished reception</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <InquiryCta lang={lang} />
  </article>
</BaseLayout>
