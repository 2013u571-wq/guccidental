---
import BaseLayout from "@components/layout/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import { chairModels, products, type ChairModel, type ChairTier } from "@data/products";
import { getLanguage, languages, localizedPath } from "@lib/i18n";

const tierContent = {
  economic: {
    title: "Economic Dental Chairs",
    description: "Reliable core function for cost-sensitive clinics and volume projects."
  },
  "mid-range": {
    title: "Mid-range Dental Chairs",
    description: "Balanced comfort and configuration for everyday practice."
  },
  "high-end": {
    title: "High-end Dental Chairs",
    description: "Premium upholstery and implant-ready configurations."
  }
} as const;

const tierSwitches = [
  { tier: "high-end", label: "High-end", count: 22 },
  { tier: "mid-range", label: "Mid-range", count: 16 },
  { tier: "economic", label: "Economic", count: 10 }
] as const;

export function getStaticPaths() {
  return languages.flatMap((language) =>
    (["economic", "mid-range", "high-end"] as ChairTier[]).map((tier) => ({ params: { lang: language.code, tier } }))
  );
}

const lang = getLanguage(Astro.params.lang);
const tier = String(Astro.params.tier) as ChairTier;
const content = tierContent[tier];

if (!content) {
  return Astro.redirect(localizedPath(lang, "/products/dental-chair/"));
}

const models = chairModels.filter((model) => model.chairTier === tier);
const count = models.length;
const productDetails = new Map(
  products
    .filter((product) => product.category === "dental-chair")
    .map((product) => [product.model, product])
);
const modelGroups = Array.from(
  models.reduce((groups, model) => {
    const seriesModels = groups.get(model.series) ?? [];
    seriesModels.push(model);
    groups.set(model.series, seriesModels);
    return groups;
  }, new Map<string, ChairModel[]>())
).map(([series, seriesModels]) => ({
  series,
  models: seriesModels,
  id: `${tier}-${series}`
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "")
}));
const inquiryHref = (model: string) =>
  localizedPath(lang, `/contact/?message=${encodeURIComponent(`I'm interested in the ${model} dental chair.`)}`);
---

<BaseLayout title={`${content.title} — ${count} Models`} description={`${content.description} ${count} models available.`} lang={lang} pathname={Astro.url.pathname}>
  <section class="chair-tier-hero">
    <div class="container">
      <nav class="chair-tier-breadcrumb" aria-label="Breadcrumb">
        <a href={localizedPath(lang, "/products/")}>Products</a>
        <span aria-hidden="true">/</span>
        <a href={localizedPath(lang, "/products/dental-chair/")}>Dental Chair</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{content.title.replace(" Dental Chairs", "")}</span>
      </nav>
      <p class="chair-tier-eyebrow">Dental Chair</p>
      <h1>{content.title}</h1>
      <p class="chair-tier-summary">{content.description} {count} models available.</p>
      <Button href={localizedPath(lang, "/contact/?category=dental-chair")}>Ask for Quote</Button>
      <nav class="tier-switch" aria-label="Dental chair tiers">
        {tierSwitches.map((item) => (
          <a href={localizedPath(lang, `/products/dental-chair/${item.tier}/`)} aria-current={item.tier === tier ? "page" : undefined}>
            {item.label} <span>{item.count}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section class="chair-tier-models">
    <div class="container">
      <nav class="tier-series-jump" aria-label={`${content.title} series`}>
        <span class="tier-series-jump-label">Jump to</span>
        {
          modelGroups.map((group) => (
            <a href={`#${group.id}`}>{group.series}</a>
          ))
        }
      </nav>

      <div class="tier-model-groups">
        {
          modelGroups.map((group) => (
            <section class="tier-model-group" id={group.id} aria-labelledby={`${group.id}-title`}>
              <header class="tier-group-head">
                <h2 id={`${group.id}-title`}>{group.series}</h2>
                <span class="tier-group-count">{group.models.length} {group.models.length === 1 ? "model" : "models"}</span>
                <span class="tier-group-rule" aria-hidden="true"></span>
              </header>

              <div class="tier-group-rows">
                {
                  group.models.map((model) => {
                    const detail = productDetails.get(model.model);
                    const detailHref = model.detailSlug
                      ? localizedPath(lang, `/products/dental-chair/${model.detailSlug}/`)
                      : undefined;
                    const implantReady = model.model.includes("Implant");

                    return (
                      <article class="tier-model-row">
                        <div class="tier-model-thumb" aria-hidden="true">
                          <svg viewBox="0 0 112 72" aria-hidden="true">
                            <path d="M18 46h48c6 0 10 4 10 9v2H27c-5 0-9-4-9-9v-2Z"></path>
                            <path d="M27 45 17 25c-2-4 0-8 4-9l3-1c4-1 7 1 9 5l10 22"></path>
                            <path d="m39 55-8 10h33l-6-8"></path>
                            <path d="M68 46h17V29h10"></path>
                            <path d="M77 30V15h18"></path>
                            <path d="M88 15v8"></path>
                            <path d="M82 23h13"></path>
                            <path d="M84 31h15v12H84z"></path>
                            <circle cx="87" cy="36" r="1"></circle>
                            <circle cx="92" cy="36" r="1"></circle>
                            <circle cx="97" cy="36" r="1"></circle>
                            <path d="M72 43h28"></path>
                          </svg>
                          <span>Photo</span>
                        </div>

                        <div class="tier-model-meta">
                          {
                            detailHref ? (
                              <a class="tier-model-name" href={detailHref}>{model.model}</a>
                            ) : (
                              <span class="tier-model-name">{model.model}</span>
                            )
                          }
                          {detail?.summary && <p>{detail.summary}</p>}
                          {
                            implantReady && (
                              <div class="tier-model-chips" aria-label={`${model.model} configuration`}>
                                <span>Implant-ready</span>
                              </div>
                            )
                          }
                        </div>

                        <div class="tier-model-actions">
                          {
                            detailHref && (
                              <a class="tier-model-details" href={detailHref}>
                                Details <span aria-hidden="true">→</span>
                              </a>
                            )
                          }
                          <a class="tier-model-inquiry" href={inquiryHref(model.model)}>Inquiry</a>
                        </div>
                      </article>
                    );
                  })
                }
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <InquiryCta lang={lang} title={`Request ${content.title} Details`} />
</BaseLayout>
