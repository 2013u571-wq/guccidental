  <!-- FILL: B100L Ultra 最终询盘引导 — 复用项目现有询盘组件，并预填型号名称。 -->
  <InquiryCta contactHref={contactHref} message={b100Message} />

  <script>
    document.querySelectorAll("[data-gallery]").forEach((gallery) => {
      const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
      const stage = gallery.querySelector<HTMLButtonElement>("[data-gallery-stage]");
      const counter = gallery.querySelector<HTMLElement>("[data-gallery-count]");
      const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-src]"));
      const lightbox = gallery.querySelector<HTMLElement>("[data-gallery-lightbox]");
      const lightboxDialog = gallery.querySelector<HTMLElement>("[data-lightbox-dialog]");
      const lightboxImage = gallery.querySelector<HTMLImageElement>("[data-lightbox-image]");
      const lightboxStage = gallery.querySelector<HTMLElement>("[data-lightbox-stage]");
      const lightboxCounter = gallery.querySelector<HTMLElement>("[data-lightbox-count]");
      const previousButton = gallery.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
      const nextButton = gallery.querySelector<HTMLButtonElement>("[data-lightbox-next]");
      const closeButtons = Array.from(gallery.querySelectorAll<HTMLElement>("[data-lightbox-close]"));
      if (!main || !stage || !thumbs.length || !lightbox || !lightboxDialog || !lightboxImage || !lightboxStage) return;

      let activeIndex = 0;
      let lastFocusedElement: HTMLElement | null = null;
      let previousBodyOverflow = "";
      let lightboxScale = 1;
      let pinchStartDistance = 0;
      let pinchStartScale = 1;
      const pointers = new Map<number, { x: number; y: number }>();
      const canHoverZoom = window.matchMedia("(min-width: 961px) and (hover: hover) and (pointer: fine)");

      const getImageData = (index: number) => {
        const thumb = thumbs[index];
        return {
          src: thumb?.dataset.gallerySrc ?? "",
          alt: thumb?.dataset.galleryAlt ?? "B100L Ultra dental chair",
        };
      };

      const resetLightboxZoom = () => {
        lightboxScale = 1;
        pinchStartDistance = 0;
        pinchStartScale = 1;
        pointers.clear();
        lightboxImage.style.transform = "";
      };

      const updateLightboxImage = () => {
        const { src, alt } = getImageData(activeIndex);
        if (src) lightboxImage.src = src;
        lightboxImage.alt = alt;
        if (lightboxCounter) lightboxCounter.textContent = `${activeIndex + 1} / ${thumbs.length}`;
        resetLightboxZoom();
      };

      const setActiveImage = (index: number, revealThumbnail = false) => {
        activeIndex = (index + thumbs.length) % thumbs.length;
        const { src, alt } = getImageData(activeIndex);
        thumbs.forEach((thumb, thumbIndex) => {
          const isActive = thumbIndex === activeIndex;
          thumb.classList.toggle("is-active", isActive);
          thumb.setAttribute("aria-pressed", String(isActive));
        });
        if (src) main.src = src;
        main.alt = alt;
        stage.setAttribute("aria-label", `Enlarge ${alt.toLowerCase()}`);
        if (counter) counter.textContent = `${activeIndex + 1} / ${thumbs.length}`;
        if (lightbox.classList.contains("is-open")) updateLightboxImage();
        if (revealThumbnail) {
          thumbs[activeIndex]?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
        }
      };

      const closeLightbox = () => {
        if (!lightbox.classList.contains("is-open")) return;
        lightbox.classList.remove("is-open");
        lightbox.setAttribute("aria-hidden", "true");
        document.body.style.overflow = previousBodyOverflow;
        resetLightboxZoom();
        lastFocusedElement?.focus();
      };

      const openLightbox = () => {
        lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : stage;
        previousBodyOverflow = document.body.style.overflow;
        updateLightboxImage();
        lightbox.classList.add("is-open");
        lightbox.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
        requestAnimationFrame(() => {
          gallery.querySelector<HTMLButtonElement>(".b100-lightbox-close")?.focus();
        });
      };

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener("click", () => setActiveImage(index));
      });

      stage.addEventListener("mousemove", (event) => {
        if (!canHoverZoom.matches) return;
        const bounds = stage.getBoundingClientRect();
        const x = ((event.clientX - bounds.left) / bounds.width) * 100;
        const y = ((event.clientY - bounds.top) / bounds.height) * 100;
        stage.style.setProperty("--gallery-zoom-x", `${Math.max(0, Math.min(100, x))}%`);
        stage.style.setProperty("--gallery-zoom-y", `${Math.max(0, Math.min(100, y))}%`);
        stage.classList.add("is-zooming");
      });
      stage.addEventListener("mouseleave", () => stage.classList.remove("is-zooming"));
      stage.addEventListener("click", openLightbox);

      previousButton?.addEventListener("click", () => setActiveImage(activeIndex - 1, true));
      nextButton?.addEventListener("click", () => setActiveImage(activeIndex + 1, true));
      closeButtons.forEach((button) => button.addEventListener("click", closeLightbox));

      lightbox.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          event.preventDefault();
          closeLightbox();
          return;
        }
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setActiveImage(activeIndex - 1, true);
          return;
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          setActiveImage(activeIndex + 1, true);
          return;
        }
        if (event.key !== "Tab") return;
        const focusable = Array.from(
          lightboxDialog.querySelectorAll<HTMLElement>('button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])'),
        ).filter((element) => !element.hasAttribute("hidden"));
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      });

      const pointerDistance = () => {
        const [first, second] = Array.from(pointers.values());
        return first && second ? Math.hypot(second.x - first.x, second.y - first.y) : 0;
      };

      lightboxStage.addEventListener("pointerdown", (event) => {
        if (event.pointerType !== "touch") return;
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        lightboxStage.setPointerCapture(event.pointerId);
        if (pointers.size === 2) {
          pinchStartDistance = pointerDistance();
          pinchStartScale = lightboxScale;
        }
      });
      lightboxStage.addEventListener("pointermove", (event) => {
        if (!pointers.has(event.pointerId)) return;
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        if (pointers.size !== 2 || !pinchStartDistance) return;
        event.preventDefault();
        lightboxScale = Math.max(1, Math.min(4, pinchStartScale * (pointerDistance() / pinchStartDistance)));
        lightboxImage.style.transform = `scale(${lightboxScale})`;
      });
      const releasePointer = (event: PointerEvent) => {
        pointers.delete(event.pointerId);
        if (pointers.size < 2) {
          pinchStartDistance = 0;
          pinchStartScale = lightboxScale;
        }
      };
      lightboxStage.addEventListener("pointerup", releasePointer);
      lightboxStage.addEventListener("pointercancel", releasePointer);

      setActiveImage(0);
    });

    document.querySelectorAll("[data-color-browser]").forEach((browser) => {
      const image = browser.querySelector<HTMLImageElement>("[data-color-image]");
      const currentName = browser.querySelector<HTMLElement>("[data-color-current-name]");
      const description = browser.querySelector<HTMLElement>("[data-color-copy]");
      const options = Array.from(browser.querySelectorAll<HTMLButtonElement>("[data-color-option]"));
      if (!image || !currentName || !description || !options.length) return;

      const setActiveColor = (option: HTMLButtonElement) => {
        const nextImage = option.dataset.colorImage;
        const code = option.dataset.colorCode ?? "";
        const name = option.dataset.colorName ?? "";
        if (nextImage) image.src = nextImage;
        image.alt = option.dataset.colorAlt ?? "B100L Ultra dental chair";
        currentName.textContent = `${code} · ${name}`;
        description.textContent = option.dataset.colorDesc ?? "";
        options.forEach((item) => {
          const isActive = item === option;
          item.classList.toggle("is-active", isActive);
          item.setAttribute("aria-pressed", String(isActive));
        });
      };

      options.forEach((option) => {
        option.addEventListener("mouseenter", () => setActiveColor(option));
        option.addEventListener("click", () => setActiveColor(option));
        option.addEventListener("focus", () => setActiveColor(option));
      });
      setActiveColor(options[0]);
    });

    document.querySelectorAll(".b100-section-nav").forEach((nav) => {
      const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'));
      const tabRail = nav.querySelector<HTMLElement>(".container");
      const sections = links
        .map((link) => document.querySelector<HTMLElement>(link.hash))
        .filter((section): section is HTMLElement => Boolean(section));
      let scrollFrame = 0;

      const setActiveTab = (sectionId: string, reveal = false) => {
        links.forEach((link) => {
          const isActive = link.hash === `#${sectionId}`;
          if (isActive) {
            link.setAttribute("aria-current", "true");
            if (reveal && tabRail) {
              const centeredLeft = link.offsetLeft - (tabRail.clientWidth - link.offsetWidth) / 2;
              tabRail.scrollTo({ left: Math.max(0, centeredLeft), behavior: "smooth" });
            }
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      const updateActiveTab = () => {
        const activationLine = Math.min(180, window.innerHeight * 0.28);
        const activeSection = sections.reduce((active, section) => (
          section.getBoundingClientRect().top <= activationLine ? section : active
        ), sections[0]);
        if (activeSection) setActiveTab(activeSection.id, true);
      };

      links.forEach((link) => {
        link.addEventListener("click", () => setActiveTab(link.hash.slice(1), true));
      });
      window.addEventListener("scroll", () => {
        cancelAnimationFrame(scrollFrame);
        scrollFrame = requestAnimationFrame(updateActiveTab);
      }, { passive: true });
      window.addEventListener("resize", updateActiveTab);
      updateActiveTab();
    });

    document.querySelectorAll("[data-faq-list]").forEach((list) => {
      list.querySelectorAll("article").forEach((item) => {
        const button = item.querySelector("button");
        if (!button) return;
        button.addEventListener("click", () => {
          const willOpen = !item.classList.contains("is-open");
          list.querySelectorAll("article.is-open").forEach((openItem) => {
            openItem.classList.remove("is-open");
            openItem.querySelector("button")?.setAttribute("aria-expanded", "false");
          });
          if (willOpen) {
            item.classList.add("is-open");
            button.setAttribute("aria-expanded", "true");
          }
        });
      });
    });
  </script>
</BaseLayout>
