---
import BaseLayout from "@components/layout/BaseLayout.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import { getLanguage, languages, localizedPath } from "@lib/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLanguage(Astro.params.lang);
const b100Message = "I'm interested in the B100 Ultra dental chair.";
const datasheetMessage = "Please send me the B100 Ultra technical datasheet and configuration options.";
const inquiryHref = localizedPath(lang, `/contact/?message=${encodeURIComponent(b100Message)}`);
const datasheetHref = localizedPath(lang, `/contact/?message=${encodeURIComponent(datasheetMessage)}`);
const contactHref = localizedPath(lang, "/contact/");
const tierHref = localizedPath(lang, "/products/dental-chair/high-end/");
const productImageBase = "/images/products/dental-chair/b100-ultra";
const galleryImages = [
  {
    src: `${productImageBase}/b100-ultra-front-view.webp`,
    alt: "B100 Ultra dental chair in green upholstery, front three-quarter view",
    label: "Front view",
    width: 1800,
    height: 1604,
  },
  {
    src: `${productImageBase}/b100-ultra-rear-view.webp`,
    alt: "B100 Ultra dental chair viewed from the rear",
    label: "Rear view",
    width: 1400,
    height: 1248,
  },
  {
    src: `${productImageBase}/b100-ultra-overhead-view.webp`,
    alt: "Overhead view of the B100 Ultra dental chair and delivery system",
    label: "Overhead view",
    width: 1400,
    height: 1248,
  },
  {
    src: `${productImageBase}/b100-ultra-delivery-unit-console.webp`,
    alt: "B100 Ultra delivery unit with seven-inch touchscreen and handpiece holders",
    label: "Delivery unit",
    width: 1400,
    height: 1248,
  },
  {
    src: `${productImageBase}/b100-ultra-side-profile.webp`,
    alt: "B100 Ultra dental chair in green upholstery, side profile",
    label: "Side profile",
    width: 1400,
    height: 1248,
  },
];
const colorImageBase = `${productImageBase}/colors`;
const colorThumbnail = (src: string) => src.replace("/colors/", "/colors/thumbs/").replace(".webp", "-thumb.webp");
const upholsteryColors = [
  {
    code: "K01",
    name: "Cream White",
    src: `${colorImageBase}/b100-ultra-k01-cream-white.webp`,
    alt: "B100 Ultra dental chair with K01 Cream White full-silicone upholstery",
    description: "A soft neutral upholstery option for bright, minimal treatment rooms.",
    swatch: "#d7d3ca",
  },
  {
    code: "K02",
    name: "Gray Purple",
    src: `${colorImageBase}/b100-ultra-k02-gray-purple.webp`,
    alt: "B100 Ultra dental chair with K02 Gray Purple full-silicone upholstery",
    description: "A muted gray-purple finish for calm, contemporary clinic interiors.",
    swatch: "#aaa6b1",
  },
  {
    code: "K03",
    name: "Brown",
    src: `${colorImageBase}/b100-ultra-k03-brown.webp`,
    alt: "B100 Ultra dental chair with K03 Brown full-silicone upholstery",
    description: "A balanced warm brown selected for natural, hospitality-led spaces.",
    swatch: "#918b7c",
  },
  {
    code: "K04",
    name: "Sky Gray",
    src: `${colorImageBase}/b100-ultra-k04-sky-gray.webp`,
    alt: "B100 Ultra dental chair with K04 Sky Gray full-silicone upholstery",
    description: "A practical cool gray that pairs easily with clinical cabinetry.",
    swatch: "#7d858d",
  },
  {
    code: "K05",
    name: "Glacier Blue",
    src: `${colorImageBase}/b100-ultra-k05-glacier-blue.webp`,
    alt: "B100 Ultra dental chair with K05 Glacier Blue full-silicone upholstery",
    description: "A clear light blue that gives treatment rooms a clean, open feel.",
    swatch: "#62b8c9",
  },
  {
    code: "K06",
    name: "Ocean Blue",
    src: `${colorImageBase}/b100-ultra-k06-ocean-blue.webp`,
    alt: "B100 Ultra dental chair with K06 Ocean Blue full-silicone upholstery",
    description: "A confident medium blue suited to modern general-practice rooms.",
    swatch: "#2f62a5",
  },
  {
    code: "K07",
    name: "Sky Blue",
    src: `${colorImageBase}/b100-ultra-k07-sky-blue.webp`,
    alt: "B100 Ultra dental chair with K07 Sky Blue full-silicone upholstery",
    description: "A deep blue upholstery option with a composed professional character.",
    swatch: "#254a75",
  },
  {
    code: "K08",
    name: "Coffee",
    src: `${colorImageBase}/b100-ultra-k08-coffee.webp`,
    alt: "B100 Ultra dental chair with K08 Coffee full-silicone upholstery",
    description: "A rich coffee tone for premium rooms with warm wood or stone finishes.",
    swatch: "#725b49",
  },
  {
    code: "K09",
    name: "Black",
    src: `${colorImageBase}/b100-ultra-k09-black.webp`,
    alt: "B100 Ultra dental chair with K09 Black full-silicone upholstery",
    description: "A crisp black finish for high-contrast, design-focused practices.",
    swatch: "#202427",
  },
  {
    code: "K10",
    name: "Red",
    src: `${colorImageBase}/b100-ultra-k10-red.webp`,
    alt: "B100 Ultra dental chair with K10 Red full-silicone upholstery",
    description: "A distinctive deep red for clinics that want a stronger visual identity.",
    swatch: "#743841",
  },
  {
    code: "K11",
    name: "Orange",
    src: `${colorImageBase}/b100-ultra-k11-orange.webp`,
    alt: "B100 Ultra dental chair with K11 Orange full-silicone upholstery",
    description: "A warm orange designed to make patient-facing rooms feel more inviting.",
    swatch: "#d97435",
  },
  {
    code: "K12",
    name: "Grass Green",
    src: `${colorImageBase}/b100-ultra-k12-grass-green.webp`,
    alt: "B100 Ultra dental chair with K12 Grass Green full-silicone upholstery",
    description: "A fresh green finish that creates an energetic, approachable treatment space.",
    swatch: "#a8ca2a",
  },
];
---

<BaseLayout
  title="B100 Ultra Dental Chair"
  description="B100 Ultra high-end digital dental chair with a seven-inch touchscreen, 24 memory positions, Philips LED light, and full-silicone upholstery."
  lang={lang}
  pathname={Astro.url.pathname}
  bodyClass="b100-detail-page"
>
  <!-- FILL: B100 Ultra 面包屑 — 当前层级已确认。 -->
  <nav class="b100-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href={localizedPath(lang, "/products/")}>Products</a></li>
        <li><a href={localizedPath(lang, "/products/dental-chair/")}>Dental Chair</a></li>
        <li><a href={tierHref}>High-end</a></li>
        <li aria-current="page">B100 Ultra</li>
      </ol>
    </div>
  </nav>

  <!-- B100 Ultra 产品图库、型号卖点和快速参数。 -->
  <section class="b100-product-hero">
    <div class="container b100-hero-layout">
      <div class="b100-gallery" data-gallery>
        <div class="b100-gallery-main">
          <img
            src={galleryImages[0].src}
            alt={galleryImages[0].alt}
            width={galleryImages[0].width}
            height={galleryImages[0].height}
            fetchpriority="high"
            decoding="async"
            data-gallery-main
          />
        </div>
        <div class="b100-gallery-thumbs" aria-label="B100 Ultra image gallery">
          {galleryImages.map((image, index) => (
            <button
              class:list={["b100-thumb", { "is-active": index === 0 }]}
              type="button"
              aria-label={`Show ${image.label.toLowerCase()} of the B100 Ultra dental chair`}
              data-gallery-src={image.src}
              data-gallery-alt={image.alt}
            >
              <img
                src={image.src}
                alt=""
                width={image.width}
                height={image.height}
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
              <span>{image.label}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="b100-hero-copy">
        <span class="b100-tier-badge">High-end Series</span>
        <h1>B100 Ultra Dental Chair</h1>
        <p class="b100-product-model">Full digital left/right dental chair</p>
        <p class="b100-tagline">A fully digital American-style dental chair for premium practices, combining a one-minute left/right workflow with a seven-inch touchscreen control system and smart chair memory.</p>

        <div class="b100-quick-specs">
          <div><span>Chair positions</span><strong>24 memory positions</strong></div>
          <div><span>Operating light</span><strong>Philips 8-bead LED</strong></div>
          <div><span>Upholstery</span><strong>Full silicone leather · 12 colors</strong></div>
          <div><span>Warranty</span><strong>3 years · spare parts support</strong></div>
        </div>

        <div class="b100-hero-actions">
          <a class="b100-btn b100-btn-primary" href={inquiryHref}>Send Inquiry</a>
          <a class="b100-btn b100-btn-secondary" href="#product-resources">Request Datasheet</a>
        </div>

        <div class="b100-trust-mini" aria-label="Product trust highlights">
          <span><i></i>Seven-inch HD touchscreen</span>
          <span><i></i>350 kg load capacity</span>
          <span><i></i>One-minute left/right switching</span>
        </div>
      </div>
    </div>
  </section>

  <nav class="b100-section-nav" aria-label="B100 Ultra page sections">
    <div class="container">
      <a href="#overview" aria-current="true">Overview</a>
      <a href="#features">Features</a>
      <a href="#colors">Colors</a>
      <a href="#specifications">Specifications</a>
      <a href="#product-resources">Resources</a>
      <a href="#faq">FAQ</a>
    </div>
  </nav>

  <!-- B100 Ultra 核心卖点 — 根据产品资料归纳为数字化、工作流、记忆位与承重舒适性。 -->
  <section class="b100-points-band" id="overview">
    <div class="container">
      <div class="b100-points-layout">
        <div class="b100-points-content">
          <header class="b100-points-heading">
            <span class="b100-eyebrow">Key selling points</span>
            <h2>Why clinics choose the B100 Ultra</h2>
          </header>

          <div class="b100-points-grid">
            <article>
              <div class="b100-point-head">
                <span>01</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="5" y="6" width="22" height="17" rx="2"></rect>
                  <path d="M11 27h10M16 23v4M10 12h12M10 17h7"></path>
                </svg>
              </div>
              <h3>Seven-inch digital control</h3>
              <p>Control the handpiece, motor and scaler from one seven-inch HD touchscreen.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>02</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M7 11h17l-4-4M25 21H8l4 4M24 11l-4 4M8 21l4-4"></path>
                </svg>
              </div>
              <h3>One-minute left/right switching</h3>
              <p>Switch between left- and right-handed layouts in about one minute.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>03</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <circle cx="12" cy="11" r="4"></circle>
                  <path d="M5 25c.7-4.3 3-6.5 7-6.5s6.3 2.2 7 6.5M22 8h5v5M27 8l-7 7"></path>
                </svg>
              </div>
              <h3>24 smart chair positions</h3>
              <p>Save four preferred chair positions for each of six dentist profiles.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>04</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M16 4 26 8v7c0 6.2-3.5 10.5-10 13-6.5-2.5-10-6.8-10-13V8l10-4Z"></path>
                  <path d="m11 16 3 3 7-7"></path>
                </svg>
              </div>
              <h3>Comfort built for daily use</h3>
              <p>45 mm backrest, synchronized motion, silicone upholstery and 350 kg capacity.</p>
            </article>
          </div>
        </div>

        <!-- TODO: 收到正式 YouTube 链接后，将此占位替换为响应式 iframe。 -->
        <aside class="b100-video-panel" aria-label="B100 Ultra product video">
          <div
            class="b100-video-placeholder"
            role="img"
            aria-label="Placeholder for the B100 Ultra product video"
          >
            <span class="b100-video-play" aria-hidden="true">
              <svg viewBox="0 0 32 32">
                <path d="m12 9 11 7-11 7V9Z"></path>
              </svg>
            </span>
            <span class="b100-video-label">Product video</span>
            <strong>See the B100 Ultra in action</strong>
            <small>YouTube video coming soon</small>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- B100 Ultra 图文特性 — 以主功能、双功能卡和全宽色卡浏览器建立清晰节奏。 -->
  <section class="b100-features-band" id="features">
    <div class="container">
      <span class="b100-eyebrow">Features</span>
      <h2>Built around the daily rhythm of a busy clinic</h2>
      <div class="b100-feature-list">
        <article class="b100-feature-focus">
          <figure class="b100-feature-media">
            <img
              src={`${productImageBase}/b100-ultra-m3-digital-control.webp`}
              alt="Close-up of the B100 Ultra M3+ seven-inch digital touchscreen control system"
              width="1600"
              height="1426"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="b100-feature-copy">
            <span class="b100-eyebrow">Digital control</span>
            <h3>M3+ digital integration system</h3>
            <p>Handpiece, electric motor and scaler are controlled from the seven-inch HD touchscreen. RPM, speed ratio, rotation direction, light status and working mode are shown in real time.</p>
            <ul>
              <li>One-screen device control</li>
              <li>Live operating status</li>
              <li>Six dentist profiles</li>
            </ul>
          </div>
        </article>

        <div class="b100-feature-pair">
          <article class="b100-feature-card">
            <figure class="b100-feature-media">
              <img
                src={`${productImageBase}/b100-ultra-synchronized-comfort.webp`}
                alt="B100 Ultra synchronized chair motion and full-body support system"
                width="1600"
                height="1426"
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="b100-feature-copy">
              <span class="b100-eyebrow">Patient comfort</span>
              <h3>Whole-body support with synchronized motion</h3>
              <p>A 45 mm ultra-thin backrest, premium-soft memory foam and skin-friendly silicone leather support the patient while 30-degree rotation improves dentist access.</p>
            </div>
          </article>
          <article class="b100-feature-card">
            <figure class="b100-feature-media">
              <img
                src={`${productImageBase}/b100-ultra-philips-led-light.webp`}
                alt="B100 Ultra Philips eight-bead LED operating light"
                width="1600"
                height="1426"
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="b100-feature-copy">
              <span class="b100-eyebrow">Operating light</span>
              <h3>Philips LED 8-bead dental light</h3>
              <p>The Philips eight-bead LED light delivers soft, even oral illumination with sensor and manual control, three light modes and 8,000–20,000 lux adjustable brightness.</p>
            </div>
          </article>
        </div>

        <article class="b100-color-feature" id="colors">
          <header>
            <span class="b100-eyebrow">Upholstery</span>
            <h3>Skin-friendly silicone leather palette</h3>
            <p>Full silicone upholstery is designed for daily disinfection, long-term use and stain resistance, with soft patient support and a choice of 12 clinic-ready colors.</p>
          </header>
          <div class="b100-content-narrow">
            <div class="b100-color-browser" data-color-browser>
              <div class="b100-color-stage">
                <div
                  class="b100-color-track"
                  aria-label="B100 Ultra upholstery color gallery"
                  tabindex="0"
                  data-color-track
                >
                  {upholsteryColors.map((color, index) => (
                    <figure
                      class="b100-color-slide"
                      id={`b100-color-slide-${index + 1}`}
                      aria-label={`${index + 1} of ${upholsteryColors.length}: ${color.code} ${color.name}`}
                      data-color-slide
                    >
                      <img
                        src={color.src}
                        alt={color.alt}
                        width="1800"
                        height="967"
                        loading="lazy"
                        decoding="async"
                      />
                      <figcaption>
                        <strong>{color.code} · {color.name}</strong>
                        <span>{color.description}</span>
                      </figcaption>
                    </figure>
                  ))}
                </div>
                <button class="b100-color-arrow is-prev" type="button" aria-label="Show previous upholstery color" data-color-prev disabled>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7"></path></svg>
                </button>
                <button class="b100-color-arrow is-next" type="button" aria-label="Show next upholstery color" data-color-next>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7"></path></svg>
                </button>
                <span class="b100-color-count" aria-live="polite" data-color-count>1 / {upholsteryColors.length}</span>
              </div>
              <div class="b100-color-thumbs" aria-label="Choose an upholstery color">
                {upholsteryColors.map((color, index) => (
                  <button
                    class:list={["b100-color-thumb", { "is-active": index === 0 }]}
                    type="button"
                    aria-label={`Show ${color.code} ${color.name} upholstery`}
                    aria-controls={`b100-color-slide-${index + 1}`}
                    aria-pressed={index === 0 ? "true" : "false"}
                    data-color-thumb={index}
                  >
                    <img
                      src={colorThumbnail(color.src)}
                      alt=""
                      width="360"
                      height="193"
                      loading="lazy"
                      decoding="async"
                      aria-hidden="true"
                    />
                    <span class="b100-color-swatch" style={`--color-swatch:${color.swatch}`}></span>
                    <span><b>{color.code}</b><small>{color.name}</small></span>
                  </button>
                ))}
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- B100 Ultra 技术参数 — 已按客户 B100L-Ultra-2.xlsx 录入。 -->
  <section class="b100-specs-band" id="specifications">
    <div class="container">
      <div class="b100-content-narrow">
        <span class="b100-eyebrow">Technical specifications</span>
        <h2>B100 Ultra full specification sheet</h2>
        <div class="b100-specs-wrap">
          <table class="b100-specs-table">
            <tbody>
              <tr><td>Model</td><td>B100 Ultra</td></tr>
              <tr><td>Type</td><td>Full digital left/right American-style dental chair</td></tr>
              <tr><td>Control system</td><td>M3+ digital integration with seven-inch HD full-color touchscreen</td></tr>
              <tr><td>Integrated device control</td><td>Handpiece, electric motor and scaler controlled on one screen</td></tr>
              <tr><td>Memory positions</td><td>24 positions · up to 6 dentists × 4 presets</td></tr>
              <tr><td>Disinfection cycles</td><td>2-minute rinse · 9-minute standard · 25-minute deep disinfection</td></tr>
              <tr><td>Left/right switching</td><td>American-style workflow conversion in about one minute</td></tr>
              <tr><td>Seat movement</td><td>30° left/right swivel</td></tr>
              <tr><td>Backrest and comfort</td><td>45 mm ultra-thin backrest · memory foam · 3 backrest speeds</td></tr>
              <tr><td>Motor</td><td>Taiwan Timotion · 10,000 N lift force · 4,000 N backrest force</td></tr>
              <tr><td>Load capacity</td><td>350 kg</td></tr>
              <tr><td>Operating light</td><td>Philips 8-bead LED · 4,000 lumens · 8,000–20,000 lux</td></tr>
              <tr><td>Assistant tray</td><td>Adjustable height and angle · delayed suction shut-off</td></tr>
              <tr><td>Upholstery</td><td>Full silicone skin-friendly leather · headrest, cover and waist pillow</td></tr>
              <tr><td>Color options</td><td>12 upholstery colors</td></tr>
              <tr><td>Warranty and included items</td><td>3 years with spare-parts support · doctor and assistant stools included</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- 尚未上传公开下载文件；改为真实的资料索取入口，避免展示无效下载。 -->
  <section class="b100-downloads-band" id="product-resources">
    <div class="container">
      <div class="b100-content-narrow">
        <div class="b100-resource-card">
          <div class="b100-resource-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32"><path d="M9 4h10l5 5v19H9z"></path><path d="M19 4v6h6M13 16h7M13 21h7"></path></svg>
          </div>
          <div>
            <span class="b100-eyebrow">Product resources</span>
            <h2>Get the B100 Ultra technical pack</h2>
            <p>Request the specification sheet, available configurations and installation requirements for procurement review.</p>
          </div>
          <div class="b100-resource-actions">
            <a class="b100-btn b100-btn-primary" href={datasheetHref}>Request Datasheet</a>
            <a class="b100-btn b100-btn-secondary" href={inquiryHref}>Discuss Configuration</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- B100 Ultra FAQ — 答案仅使用客户产品资料中已确认的功能参数。 -->
  <section class="b100-faq-band" id="faq">
    <div class="container">
      <div class="b100-content-narrow b100-faq-layout">
        <div><span class="b100-eyebrow">FAQ</span><h2>Questions about the B100 Ultra</h2></div>
        <div class="b100-faq-list" data-faq-list>
          <article class="is-open"><button type="button" aria-expanded="true"><span>Can several dentists save their own chair positions?</span><i>+</i></button><p>Yes. The system stores 24 memory positions, organized as four presets for each of up to six dentist profiles.</p></article>
          <article><button type="button" aria-expanded="false"><span>Can the B100 Ultra switch between left- and right-handed workflows?</span><i>+</i></button><p>Yes. Its American-style operating layout can be converted for left- or right-handed use in about one minute.</p></article>
          <article><button type="button" aria-expanded="false"><span>What disinfection programs are built in?</span><i>+</i></button><p>The chair provides a 2-minute rinse, a 9-minute standard disinfection cycle and a 25-minute deep disinfection cycle.</p></article>
          <article><button type="button" aria-expanded="false"><span>Which upholstery options are available?</span><i>+</i></button><p>The full-silicone, skin-friendly upholstery is offered in 12 colors and is designed for daily cleaning, stain resistance and long-term use.</p></article>
          <article><button type="button" aria-expanded="false"><span>What warranty and included accessories come with the chair?</span><i>+</i></button><p>The B100 Ultra carries a 3-year warranty with spare-parts support. Doctor and assistant stools are included.</p></article>
        </div>
      </div>
    </div>
  </section>

  <!-- Related high-end models with approved local product images. -->
  <section class="b100-related-band">
    <div class="container">
      <span class="b100-eyebrow">Related products</span>
      <h2>Other high-end dental chairs</h2>
      <div class="b100-related-grid">
        <!-- TODO: SL8500 detail page is pending; link to the High-end tier meanwhile. -->
        <a href={tierHref}>
          <span class="b100-related-media">
            <img src="/images/products/dental-chair/sl8500.webp" alt="SL8500 high-end dental chair with brown upholstery and integrated delivery unit" width="1400" height="1211" loading="lazy" decoding="async" />
          </span>
