  <script>
    document.querySelectorAll("[data-gallery]").forEach((gallery) => {
      const main = gallery.querySelector("[data-gallery-main]");
      const thumbs = gallery.querySelectorAll("[data-gallery-src]");
      if (!main || !thumbs.length) return;
      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          thumbs.forEach((item) => item.classList.remove("is-active"));
          thumb.classList.add("is-active");
          const src = thumb.getAttribute("data-gallery-src");
          const alt = thumb.getAttribute("data-gallery-alt");
          if (src) main.setAttribute("src", src);
          if (alt) main.setAttribute("alt", alt);
        });
      });
    });

    document.querySelectorAll("[data-color-browser]").forEach((browser) => {
      const track = browser.querySelector("[data-color-track]");
      const slides = Array.from(browser.querySelectorAll("[data-color-slide]"));
      const thumbs = Array.from(browser.querySelectorAll("[data-color-thumb]"));
      const previous = browser.querySelector("[data-color-prev]");
      const next = browser.querySelector("[data-color-next]");
      const count = browser.querySelector("[data-color-count]");
      if (!(track instanceof HTMLElement) || !slides.length) return;

      let activeIndex = 0;
      let scrollFrame = 0;

      const updateState = (index: number, centerThumb = false) => {
        activeIndex = Math.max(0, Math.min(index, slides.length - 1));
        thumbs.forEach((thumb, thumbIndex) => {
          const isActive = thumbIndex === activeIndex;
          thumb.classList.toggle("is-active", isActive);
          thumb.setAttribute("aria-pressed", String(isActive));
        });
        if (previous instanceof HTMLButtonElement) previous.disabled = activeIndex === 0;
        if (next instanceof HTMLButtonElement) next.disabled = activeIndex === slides.length - 1;
        if (count) count.textContent = `${activeIndex + 1} / ${slides.length}`;
        if (centerThumb) {
          thumbs[activeIndex]?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
        }
      };

      const goTo = (index: number) => {
        const nextIndex = Math.max(0, Math.min(index, slides.length - 1));
        track.scrollTo({ left: nextIndex * track.clientWidth, behavior: "smooth" });
        updateState(nextIndex, true);
      };

      thumbs.forEach((thumb, index) => thumb.addEventListener("click", () => goTo(index)));
      previous?.addEventListener("click", () => goTo(activeIndex - 1));
      next?.addEventListener("click", () => goTo(activeIndex + 1));
      track.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          goTo(activeIndex - 1);
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          goTo(activeIndex + 1);
        }
      });
      track.addEventListener("scroll", () => {
        cancelAnimationFrame(scrollFrame);
        scrollFrame = requestAnimationFrame(() => {
          const index = Math.round(track.scrollLeft / Math.max(1, track.clientWidth));
          updateState(index);
        });
      }, { passive: true });
      window.addEventListener("resize", () => {
        track.scrollTo({ left: activeIndex * track.clientWidth, behavior: "auto" });
      });
      updateState(0);
    });

    document.querySelectorAll(".b100-section-nav").forEach((nav) => {
      const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'));
      const tabRail = nav.querySelector<HTMLElement>(".container");
      const sections = links
        .map((link) => document.querySelector<HTMLElement>(link.hash))
        .filter((section): section is HTMLElement => Boolean(section));
      let scrollFrame = 0;

      const setActiveTab = (sectionId: string, reveal = false) => {
        links.forEach((link) => {
          const isActive = link.hash === `#${sectionId}`;
          if (isActive) {
            link.setAttribute("aria-current", "true");
            if (reveal && tabRail) {
              const centeredLeft = link.offsetLeft - (tabRail.clientWidth - link.offsetWidth) / 2;
              tabRail.scrollTo({ left: Math.max(0, centeredLeft), behavior: "smooth" });
            }
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      const updateActiveTab = () => {
        const activationLine = Math.min(180, window.innerHeight * 0.28);
        const activeSection = sections.reduce((active, section) => (
          section.getBoundingClientRect().top <= activationLine ? section : active
        ), sections[0]);
        if (activeSection) setActiveTab(activeSection.id, true);
      };

      links.forEach((link) => {
        link.addEventListener("click", () => setActiveTab(link.hash.slice(1), true));
      });
      window.addEventListener("scroll", () => {
        cancelAnimationFrame(scrollFrame);
        scrollFrame = requestAnimationFrame(updateActiveTab);
      }, { passive: true });
      window.addEventListener("resize", updateActiveTab);
      updateActiveTab();
    });

    document.querySelectorAll("[data-faq-list]").forEach((list) => {
      list.querySelectorAll("article").forEach((item) => {
        const button = item.querySelector("button");
        if (!button) return;
        button.addEventListener("click", () => {
          const willOpen = !item.classList.contains("is-open");
          list.querySelectorAll("article.is-open").forEach((openItem) => {
            openItem.classList.remove("is-open");
            openItem.querySelector("button")?.setAttribute("aria-expanded", "false");
          });
          if (willOpen) {
            item.classList.add("is-open");
            button.setAttribute("aria-expanded", "true");
          }
        });
      });
    });
  </script>
</BaseLayout>
