---
import BaseLayout from "@components/layout/BaseLayout.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import { getLanguage, languages, localizedPath } from "@lib/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLanguage(Astro.params.lang);
const b100Message = "I'm interested in the B100L Ultra dental chair.";
const inquiryHref = localizedPath(lang, `/contact/?message=${encodeURIComponent(b100Message)}`);
const datasheetHref = "https://media.guccidental.com/documents/products/dental-chair/b100l-ultra/b100l-ultra-catalog.pdf";
const manualHref = import.meta.env.DEV
  ? "/downloads/guccidental-b100-series-user-manual.pdf"
  : "https://media.guccidental.com/downloads/guccidental-b100-series-user-manual.pdf";
const contactHref = localizedPath(lang, "/contact/");
const tierHref = localizedPath(lang, "/products/dental-chair/high-end/");
const productImageBase = "https://media.guccidental.com/images/products/dental-chair/b100-ultra";
const galleryImages = [
  {
    src: `${productImageBase}/b100-ultra-blue-front-three-quarter.webp`,
    alt: "B100L Ultra dental chair with blue upholstery in a complete front three-quarter view",
    label: "Front three-quarter view",
    width: 2400,
    height: 1620,
  },
  {
    src: `${productImageBase}/b100-ultra-blue-rear-operator-workflow.webp`,
    alt: "Rear operator view of the B100L Ultra dental chair with blue upholstery, dentist unit and assistant instruments",
    label: "Rear operator workflow",
    width: 2400,
    height: 1620,
  },
  {
    src: `${productImageBase}/b100-ultra-blue-overhead-right-handed-workflow.webp`,
    alt: "Overhead view of the B100L Ultra dental chair configured for a right-handed clinical workflow",
    label: "Right-handed workflow",
    width: 2400,
    height: 1620,
  },
  {
    src: `${productImageBase}/b100-ultra-blue-overhead-left-handed-workflow.webp`,
    alt: "Overhead view of the B100L Ultra dental chair configured for a left-handed clinical workflow",
    label: "Left-handed workflow",
    width: 2400,
    height: 1620,
  },
];
const colorImageBase = `${productImageBase}/colors`;
const colorSwatchBase = `${colorImageBase}/swatches`;
const upholsteryColors = [
  {
    code: "K01",
    name: "Cream White",
    swatch: `${colorSwatchBase}/b100-ultra-k01-cream-white-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k01-cream-white.webp`,
    alt: "B100L Ultra dental chair with K01 Cream White full-silicone upholstery",
    desc: "A soft neutral upholstery option for bright, minimal treatment rooms.",
  },
  {
    code: "K02",
    name: "Gray Purple",
    swatch: `${colorSwatchBase}/b100-ultra-k02-gray-purple-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k02-gray-purple.webp`,
    alt: "B100L Ultra dental chair with K02 Gray Purple full-silicone upholstery",
    desc: "K02 upholstery description pending.",
  },
  {
    code: "K03",
    name: "Brown",
    swatch: `${colorSwatchBase}/b100-ultra-k03-brown-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k03-brown.webp`,
    alt: "B100L Ultra dental chair with K03 Brown full-silicone upholstery",
    desc: "K03 upholstery description pending.",
  },
  {
    code: "K04",
    name: "Sky Gray",
    swatch: `${colorSwatchBase}/b100-ultra-k04-sky-gray-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k04-sky-gray.webp`,
    alt: "B100L Ultra dental chair with K04 Sky Gray full-silicone upholstery",
    desc: "K04 upholstery description pending.",
  },
  {
    code: "K05",
    name: "Glacier Blue",
    swatch: `${colorSwatchBase}/b100-ultra-k05-glacier-blue-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k05-glacier-blue.webp`,
    alt: "B100L Ultra dental chair with K05 Glacier Blue full-silicone upholstery",
    desc: "K05 upholstery description pending.",
  },
  {
    code: "K06",
    name: "Ocean Blue",
    swatch: `${colorSwatchBase}/b100-ultra-k06-ocean-blue-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k06-ocean-blue.webp`,
    alt: "B100L Ultra dental chair with K06 Ocean Blue full-silicone upholstery",
    desc: "K06 upholstery description pending.",
  },
  {
    code: "K07",
    name: "Sky Blue",
    swatch: `${colorSwatchBase}/b100-ultra-k07-sky-blue-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k07-sky-blue.webp`,
    alt: "B100L Ultra dental chair with K07 Sky Blue full-silicone upholstery",
    desc: "K07 upholstery description pending.",
  },
  {
    code: "K08",
    name: "Coffee",
    swatch: `${colorSwatchBase}/b100-ultra-k08-coffee-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k08-coffee.webp`,
    alt: "B100L Ultra dental chair with K08 Coffee full-silicone upholstery",
    desc: "K08 upholstery description pending.",
  },
  {
    code: "K09",
    name: "Black",
    swatch: `${colorSwatchBase}/b100-ultra-k09-black-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k09-black.webp`,
    alt: "B100L Ultra dental chair with K09 Black full-silicone upholstery",
    desc: "K09 upholstery description pending.",
  },
  {
    code: "K10",
    name: "Red",
    swatch: `${colorSwatchBase}/b100-ultra-k10-red-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k10-red.webp`,
    alt: "B100L Ultra dental chair with K10 Red full-silicone upholstery",
    desc: "K10 upholstery description pending.",
  },
  {
    code: "K11",
    name: "Orange",
    swatch: `${colorSwatchBase}/b100-ultra-k11-orange-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k11-orange.webp`,
    alt: "B100L Ultra dental chair with K11 Orange full-silicone upholstery",
    desc: "K11 upholstery description pending.",
  },
  {
    code: "K12",
    name: "Grass Green",
    swatch: `${colorSwatchBase}/b100-ultra-k12-grass-green-swatch.webp`,
    image: `${colorImageBase}/b100-ultra-k12-grass-green.webp`,
    alt: "B100L Ultra dental chair with K12 Grass Green full-silicone upholstery",
    desc: "K12 upholstery description pending.",
  },
];
---

<BaseLayout
  title="B100L Ultra Dental Chair"
  description="B100L Ultra high-end digital dental chair with a seven-inch touchscreen, 24 memory positions, Philips LED light, and full-silicone upholstery."
  lang={lang}
  pathname={Astro.url.pathname}
  bodyClass="b100-detail-page"
>
  <!-- FILL: B100L Ultra 面包屑 — 当前层级已确认。 -->
  <nav class="b100-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href={localizedPath(lang, "/products/")}>Products</a></li>
        <li><a href={localizedPath(lang, "/products/dental-chair/")}>Dental Chair</a></li>
        <li><a href={tierHref}>High-end</a></li>
        <li aria-current="page">B100L Ultra</li>
      </ol>
    </div>
  </nav>

  <!-- B100L Ultra 产品图库、型号卖点和快速参数。 -->
  <section class="b100-product-hero">
    <div class="container b100-hero-layout">
      <div class="b100-gallery" data-gallery>
        <button
          class="b100-gallery-main"
          type="button"
          aria-label={`Enlarge ${galleryImages[0].alt.toLowerCase()}`}
          data-gallery-stage
        >
          <span class="b100-gallery-shadow" aria-hidden="true"></span>
          <img
            src={galleryImages[0].src}
            alt={galleryImages[0].alt}
            width={galleryImages[0].width}
            height={galleryImages[0].height}
            fetchpriority="high"
            decoding="async"
            data-gallery-main
          />
          <span class="b100-gallery-tier">High-end</span>
          <span class="b100-gallery-count" data-gallery-count>1 / {galleryImages.length}</span>
          <span class="b100-gallery-hint">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="10.8" cy="10.8" r="6.4"></circle>
              <path d="m15.5 15.5 4.1 4.1M10.8 8v5.6M8 10.8h5.6"></path>
            </svg>
            <span>Hover to zoom · click to enlarge</span>
          </span>
        </button>

        <div class="b100-gallery-thumbs" role="group" aria-label="B100L Ultra image gallery">
          {galleryImages.map((image, index) => (
            <button
              class:list={["b100-thumb", { "is-active": index === 0 }]}
              type="button"
              aria-label={`Show ${image.label.toLowerCase()} of the B100L Ultra dental chair`}
              aria-pressed={index === 0 ? "true" : "false"}
              data-gallery-src={image.src}
              data-gallery-alt={image.alt}
              data-gallery-index={index}
              data-tooltip={image.label}
              title={image.label}
            >
              <img
                src={image.src}
                alt=""
                width={image.width}
                height={image.height}
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
            </button>
          ))}
        </div>

        <div
          class="b100-lightbox"
          role="dialog"
          aria-modal="true"
          aria-label="B100L Ultra image viewer"
          aria-hidden="true"
          data-gallery-lightbox
        >
          <div class="b100-lightbox-backdrop" data-lightbox-close></div>
          <div class="b100-lightbox-dialog" role="document" tabindex="-1" data-lightbox-dialog>
            <button class="b100-lightbox-close" type="button" aria-label="Close image viewer" data-lightbox-close>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 5l14 14M19 5 5 19"></path>
              </svg>
            </button>
            <button class="b100-lightbox-arrow is-prev" type="button" aria-label="Previous image" data-lightbox-prev>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m15 5-7 7 7 7"></path>
              </svg>
            </button>
            <div class="b100-lightbox-stage" data-lightbox-stage>
              <img
                src={galleryImages[0].src}
                alt={galleryImages[0].alt}
                width={galleryImages[0].width}
                height={galleryImages[0].height}
                decoding="async"
                draggable="false"
                data-lightbox-image
              />
            </div>
            <span class="b100-lightbox-count" data-lightbox-count>1 / {galleryImages.length}</span>
            <button class="b100-lightbox-arrow is-next" type="button" aria-label="Next image" data-lightbox-next>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m9 5 7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="b100-hero-copy">
        <span class="b100-tier-badge">High-end Series</span>
        <h1>B100L Ultra Dental Chair</h1>
        <p class="b100-product-model">Full digital left/right dental chair</p>
        <p class="b100-tagline">A fully digital American-style dental chair for premium practices, combining a one-minute left/right workflow with a seven-inch touchscreen control system and smart chair memory.</p>

        <div class="b100-quick-specs">
          <div><span>Chair positions</span><strong>24 memory positions</strong></div>
          <div><span>Operating light</span><strong>Philips 8-bead LED</strong></div>
          <div><span>Upholstery</span><strong>Full silicone leather · 12 colors</strong></div>
          <div><span>Warranty</span><strong>2 years · spare parts support</strong></div>
        </div>

        <div class="b100-hero-actions">
          <a class="b100-btn b100-btn-primary" href={inquiryHref}>Send Inquiry</a>
          <a class="b100-btn b100-btn-secondary" href="#product-resources">Request Datasheet</a>
        </div>

        <div class="b100-trust-mini" aria-label="Product trust highlights">
          <span><i></i>Seven-inch HD touchscreen</span>
          <span><i></i>350 kg load capacity</span>
          <span><i></i>One-minute left/right switching</span>
        </div>
      </div>
    </div>
  </section>

  <nav class="b100-section-nav" aria-label="B100L Ultra page sections">
    <div class="container">
      <a href="#overview" aria-current="true">Overview</a>
      <a href="#features">Features</a>
      <a href="#colors">Colors</a>
      <a href="#specifications">Specifications</a>
      <a href="#product-resources">Resources</a>
      <a href="#faq">FAQ</a>
    </div>
  </nav>

  <!-- B100L Ultra 核心卖点 — 根据产品资料归纳为数字化、工作流、记忆位与承重舒适性。 -->
  <section class="b100-points-band" id="overview">
    <div class="container">
      <div class="b100-points-layout">
        <div class="b100-points-content">
          <header class="b100-points-heading">
            <span class="b100-eyebrow">Key selling points</span>
            <h2>Why clinics choose the B100L Ultra</h2>
          </header>

          <div class="b100-points-grid">
            <article>
              <div class="b100-point-head">
                <span>01</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="5" y="6" width="22" height="17" rx="2"></rect>
                  <path d="M11 27h10M16 23v4M10 12h12M10 17h7"></path>
                </svg>
              </div>
              <h3>Seven-inch digital control</h3>
              <p>Control the handpiece, motor and scaler from one seven-inch HD touchscreen.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>02</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M7 11h17l-4-4M25 21H8l4 4M24 11l-4 4M8 21l4-4"></path>
                </svg>
              </div>
              <h3>One-minute left/right switching</h3>
              <p>Switch between left- and right-handed layouts in about one minute.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>03</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <circle cx="12" cy="11" r="4"></circle>
                  <path d="M5 25c.7-4.3 3-6.5 7-6.5s6.3 2.2 7 6.5M22 8h5v5M27 8l-7 7"></path>
                </svg>
              </div>
              <h3>24 smart chair positions</h3>
              <p>Save four preferred chair positions for each of six dentist profiles.</p>
            </article>
            <article>
              <div class="b100-point-head">
                <span>04</span>
                <svg class="b100-point-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M16 4 26 8v7c0 6.2-3.5 10.5-10 13-6.5-2.5-10-6.8-10-13V8l10-4Z"></path>
                  <path d="m11 16 3 3 7-7"></path>
                </svg>
              </div>
              <h3>Comfort built for daily use</h3>
              <p>45 mm backrest, synchronized motion, silicone upholstery and 350 kg capacity.</p>
            </article>
          </div>
        </div>

        <!-- TODO: 收到正式 YouTube 链接后，将此占位替换为响应式 iframe。 -->
        <aside class="b100-video-panel" aria-label="B100L Ultra product video">
          <div
            class="b100-video-placeholder"
            role="img"
            aria-label="Placeholder for the B100L Ultra product video"
          >
            <span class="b100-video-play" aria-hidden="true">
              <svg viewBox="0 0 32 32">
                <path d="m12 9 11 7-11 7V9Z"></path>
              </svg>
            </span>
            <span class="b100-video-label">Product video</span>
            <strong>See the B100L Ultra in action</strong>
            <small>YouTube video coming soon</small>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- B100L Ultra 图文特性 — 以主功能、双功能卡和全宽色卡浏览器建立清晰节奏。 -->
  <section class="b100-features-band" id="features">
    <div class="container">
      <span class="b100-eyebrow">Features</span>
      <h2>Built around the daily rhythm of a busy clinic</h2>
      <div class="b100-feature-list">
        <article class="b100-feature-focus">
          <figure class="b100-feature-media">
            <img
              src={`${productImageBase}/b100-ultra-delivery-unit-touchscreen-detail.webp`}
              alt="B100L Ultra dentist delivery unit with instrument tray, handpiece holders and seven-inch touchscreen"
              width="1800"
              height="1604"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="b100-feature-copy">
            <span class="b100-eyebrow">Digital control</span>
            <h3>Seven-inch digital command center</h3>
            <p>The doctor-side delivery unit brings the handpiece, electric motor and scaler controls together on one HD touchscreen, with the tray and instruments arranged within easy reach.</p>
            <ul>
              <li>One-screen device control</li>
              <li>Clear live operating status</li>
              <li>Organized doctor-side workflow</li>
            </ul>
          </div>
        </article>

        <div class="b100-feature-pair">
          <article class="b100-feature-card">
            <figure class="b100-feature-media">
              <img
                src={`${productImageBase}/b100-ultra-integrated-motor-control-screen.webp`}
                alt="B100L Ultra touchscreen displaying integrated electric motor settings and operating controls"
                width="1800"
                height="1604"
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="b100-feature-copy">
              <span class="b100-eyebrow">Integrated motor</span>
              <h3>Motor settings visible at a glance</h3>
              <p>The touchscreen centralizes motor speed, operating mode and related instrument settings, helping clinicians adjust treatment parameters without leaving the delivery unit.</p>
            </div>
          </article>
          <article class="b100-feature-card">
            <figure class="b100-feature-media">
              <img
                src={`${productImageBase}/b100-ultra-philips-led-operating-light-detail.webp`}
                alt="Close-up of the B100L Ultra Philips eight-bead LED operating light and articulated arm"
                width="1800"
                height="1604"
                loading="lazy"
                decoding="async"
              />
            </figure>
            <div class="b100-feature-copy">
              <span class="b100-eyebrow">Operating light</span>
              <h3>Philips LED 8-bead dental light</h3>
              <p>The Philips eight-bead LED light provides clear oral illumination at up to 40,000 lux, with an articulated arm for precise positioning over the treatment area.</p>
            </div>
          </article>
        </div>

        <article class="b100-feature-focus">
          <figure class="b100-feature-media">
            <img
              src={`${productImageBase}/b100l-ultra-ambidextrous-left-right-conversion.webp`}
              alt="Top view of the B100L Ultra dental chair showing ambidextrous left-to-right delivery unit conversion"
              width="2400"
              height="1389"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="b100-feature-copy">
            <span class="b100-eyebrow">Convertible delivery system</span>
            <h3>Quick left/right conversion in 1 minute</h3>
            <ul>
              <li>Designed for both left-handed and right-handed dentists</li>
              <li>Flexible positioning for any clinic layout</li>
              <li>Ideal for multi-doctor dental practices</li>
            </ul>
          </div>
        </article>

        <article class="b100-color-feature" id="colors">
          <header>
            <span class="b100-eyebrow">Upholstery</span>
            <h3>Skin-friendly silicone leather palette</h3>
            <p>Full silicone upholstery is designed for daily disinfection, long-term use and stain resistance, with soft patient support and a choice of 12 clinic-ready colors.</p>
          </header>
          <div class="b100-content-narrow">
            <div class="b100-color-browser" data-color-browser>
              <div class="b100-color-stage">
                <div class="b100-color-image">
                  <img
                    src={upholsteryColors[0].image}
                    alt={upholsteryColors[0].alt}
                    width="1800"
                    height="967"
                    loading="lazy"
                    decoding="async"
                    data-color-image
                  />
                </div>
                <div class="b100-color-controls">
                  <strong aria-live="polite" data-color-current-name>{upholsteryColors[0].code} · {upholsteryColors[0].name}</strong>
                  <div class="b100-color-swatches" role="group" aria-label="Choose an upholstery color">
                    {upholsteryColors.map((color, index) => (
                      <button
                        class:list={["b100-color-swatch", { "is-active": index === 0 }]}
                        type="button"
                        aria-label={`Show ${color.code} ${color.name} upholstery`}
                        aria-pressed={index === 0 ? "true" : "false"}
                        style={`--color-swatch-image:url("${color.swatch}")`}
                        data-color-option
                        data-color-code={color.code}
                        data-color-name={color.name}
                        data-color-image={color.image}
                        data-color-alt={color.alt}
                        data-color-desc={color.desc}
                      ></button>
                    ))}
                  </div>
                </div>
              </div>
              <p class="b100-color-description" aria-live="polite" data-color-copy>{upholsteryColors[0].desc}</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- B100L Ultra 技术参数 — 已按客户确认的最新参数录入。 -->
  <section class="b100-specs-band" id="specifications">
    <div class="container">
      <div class="b100-content-narrow">
        <span class="b100-eyebrow">Technical specifications</span>
        <h2>B100L Ultra full specification sheet</h2>
        <div class="b100-specs-wrap">
          <table class="b100-specs-table">
            <tbody>
              <tr><td>Model</td><td>B100L Ultra</td></tr>
              <tr><td>Tier</td><td>High-end</td></tr>
              <tr><td>Motor type</td><td>Timotion, 10,000N lift force, 4,000N backrest force</td></tr>
              <tr><td>Control panel</td><td>7" touchscreen centralizes control of electric motor, scaler, turbines</td></tr>
              <tr><td>Chair position</td><td>24 memory positions setting available</td></tr>
              <tr><td>Operating light</td><td>Philips LED 8 beads lamp, 40,000 lux</td></tr>
              <tr><td>Cuspidor</td><td>Ceramic, rotatable, removable</td></tr>
              <tr><td>Upholstery</td><td>Full silicone skin-friendly leather</td></tr>
              <tr><td>Stool</td><td>Doctor stool &amp; assistant stool, 1pcs each</td></tr>
              <tr><td>Water/gas pipes</td><td>German imported</td></tr>
              <tr><td>Solenoid valves</td><td>Italian imported</td></tr>
              <tr><td>Footswitch</td><td>Multifunctional</td></tr>
              <tr><td>Load capacity</td><td>350kg</td></tr>
              <tr><td>Overall dimensions</td><td>2210mm(L)*1450mm(W)*2150mm(H)</td></tr>
              <tr><td>Packing size</td><td>1540*1040*1220mm</td></tr>
              <tr><td>Gross weight</td><td>350kg</td></tr>
              <tr><td>Certifications</td><td>ISO, CE, FDA</td></tr>
              <tr><td>Warranty</td><td>2 years</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Product catalog is hosted on Cloudflare R2; Git stores only the public file URL. -->
  <section class="b100-downloads-band" id="product-resources">
    <div class="container">
      <div class="b100-content-narrow">
        <div class="b100-resource-card">
          <div class="b100-resource-icon" aria-hidden="true">
