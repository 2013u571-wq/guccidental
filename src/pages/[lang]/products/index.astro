---
import BaseLayout from "@components/layout/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
import FactoryProof from "@components/ui/FactoryProof.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import { getLanguage, languages, localizedPath } from "@lib/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLanguage(Astro.params.lang);

const productGroups = [
  {
    title: "Chairs & Cabinets",
    categories: [
      { title: "Dental Chair", description: "48 models across three tiers, from economic to implant-ready.", href: "/products/dental-chair/" },
      { title: "Dental Cabinet", description: "Metal and wood cabinetry for treatment and reception rooms.", href: "/products/dental-cabinet/" }
    ]
  },
  {
    title: "Treatment Equipment",
    categories: [
      { title: "Ultrasonic Scaler & Light Cure", description: "Scaling and curing equipment for daily treatment.", href: "/products/ultrasonic-scaler-light-cure/" },
      { title: "Air Equipment", description: "Compressors and vacuum systems for stable operation.", href: "/products/air-equipment/" },
      { title: "Dental Handpiece", description: "High-speed and low-speed handpieces for daily use.", href: "/products/dental-handpiece/" },
      { title: "Endo Motor", description: "Torque-controlled motors for root canal preparation.", href: "/products/endo-motor/" }
    ]
  },
  {
    title: "Imaging & Digital",
    categories: [
      { title: "Imaging System", description: "X-ray, CBCT, intraoral scanners and cameras.", href: "/products/imaging-system/" }
    ]
  },
  {
    title: "Specialty & Supplies",
    categories: [
      { title: "Orthodontics", description: "Brackets, wires and chairside orthodontic tools.", href: "/products/orthodontics/" },
      { title: "Surgical Instruments", description: "Implant motors, surgical kits and hand instruments.", href: "/products/surgical-instruments/" },
      { title: "Whitening Machine", description: "In-clinic bleaching lamps.", href: "/products/whitening-machine/" },
      { title: "Disposable Consumables", description: "Gloves, bibs, tips and everyday clinic supplies.", href: "/products/disposable-consumables/" },
      { title: "Teaching Model", description: "Phantom heads and typodonts for dental education.", href: "/products/teaching-model/" },
      { title: "Laboratory", description: "Equipment for in-house lab workflows.", href: "/products/laboratory/" }
    ]
  }
] as const;
---

<BaseLayout title="Dental Equipment Products — 13 Categories" description="Explore Guccidental dental chairs, cabinets, imaging systems, treatment equipment, and clinic supplies from one factory-direct source." lang={lang} pathname={Astro.url.pathname}>
  <section class="products-overview-hero">
    <div class="container">
      <p class="products-overview-eyebrow">Product Range</p>
      <h1>Everything a dental clinic needs, from one factory.</h1>
      <p class="products-overview-proof">13 product categories · 48 dental chair models · export documentation for 130+ countries.</p>
      <Button href={localizedPath(lang, "/contact/")} size="md">Talk to Sales</Button>
    </div>
  </section>

  <section class="products-overview-categories">
    <div class="container">
      {/* TODO: Add category imagery when a consistent product-image system is available. */}
      {productGroups.map((group) => (
        <section class="products-overview-group" aria-labelledby={`product-group-${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}`}>
          <h2 id={`product-group-${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}`}>{group.title}</h2>
          <div class="products-overview-category-grid">
            {group.categories.map((category) => (
              <article class="products-overview-category">
                <a href={localizedPath(lang, category.href)}>{category.title}</a>
                <p>{category.description}</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <FactoryProof />
  <InquiryCta lang={lang} />
</BaseLayout>
