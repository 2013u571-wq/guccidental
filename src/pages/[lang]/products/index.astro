---
import BaseLayout from "@components/layout/BaseLayout.astro";
import CategoryCard from "@components/ui/CategoryCard.astro";
import InquiryCta from "@components/ui/InquiryCta.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import { categories } from "@data/products";
import { getLanguage, languages } from "@lib/i18n";

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLanguage(Astro.params.lang);
---

<BaseLayout title="Products" description="Browse Guccidental dental equipment categories and clinic solution products." lang={lang} pathname={Astro.url.pathname}>
  <section class="bg-surface-soft">
    <div class="container py-16 md:py-22">
      <p class="mb-4 text-caption-sm uppercase tracking-[0.12em] text-brand-blue">Products</p>
      <h1 class="max-w-4xl text-[34px] font-light leading-tight md:text-display-lg">Dental Equipment Categories for Clinics and Dealers</h1>
      <p class="mt-5 max-w-3xl text-body-md text-ink-secondary">The product route structure follows the client-approved information architecture and is ready for Sanity-backed content.</p>
    </div>
  </section>
  <section class="section-band bg-white">
    <div class="container">
      <SectionHeader title="All Product Categories" summary="Category cards are generated from structured mock data and can be replaced by Sanity query results later." />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => <CategoryCard category={category} lang={lang} />)}
      </div>
    </div>
  </section>
  <InquiryCta lang={lang} />
</BaseLayout>
